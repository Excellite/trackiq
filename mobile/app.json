{
  "expo": {
    "name": "TrackIQ",
    "slug": "trackiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.trackiq.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TrackIQ needs location to track your vehicle position.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TrackIQ needs background location to log trips automatically.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "backgroundModes": [
        "location",
        "fetch",
        "location",
        "fetch"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "ng.trackiq.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "versionCode": 2
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TrackIQ needs location to track your vehicle."
        }
      ],
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "43793dbc-aebd-4543-856a-79a0b1808937"
      }
    },
    "owner": "excellite"
  }
}
